   "source": [
    "# 退火条件概率分布\n",
    "\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "\n",
    "input = torch.Tensor([5.0, 4.5, 1, 0.5])\n",
    "temperature = 0.8\n",
    "output = F.softmax(input / temperature, dim=0)\n",
    "print(output)\n",
    "temperature = 2.0\n",
    "output = F.softmax(input / temperature, dim=0)\n",
    "print(output)"
   ]
  }
 ],
